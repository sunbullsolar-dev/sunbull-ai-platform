# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================

# Node Environment
NODE_ENV=development

# Application Ports
BACKEND_PORT=4000
FRONTEND_PORT=3000
ADMIN_PORT=3001
ML_SERVICE_PORT=8000

# ============================================================================
# DATABASE & CACHING
# ============================================================================

DATABASE_URL=postgresql://sunbull:sunbull_password@localhost:5432/sunbull_db
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=sunbull
DATABASE_PASSWORD=sunbull_password
DATABASE_NAME=sunbull_db

REDIS_URL=redis://localhost:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# SOLAR & LOCATION APIs
# ============================================================================

# Google APIs
GOOGLE_SOLAR_API_KEY=your_google_solar_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# NREL PVWatts API
NREL_PVWATTS_API_KEY=your_nrel_pvwatts_api_key_here

# OpenEI API
OPENEI_API_KEY=your_openei_api_key_here

# ============================================================================
# AI & MACHINE LEARNING
# ============================================================================

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7

# ============================================================================
# COMMUNICATION SERVICES
# ============================================================================

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@sunbull.ai

# ============================================================================
# DOCUMENT & SIGNATURE SERVICES
# ============================================================================

# DocuSign
DOCUSIGN_INTEGRATION_KEY=your_docusign_integration_key_here
DOCUSIGN_ACCOUNT_ID=your_docusign_account_id_here
DOCUSIGN_USERNAME=your_docusign_username_here
DOCUSIGN_PASSWORD=your_docusign_password_here
DOCUSIGN_ENVIRONMENT=sandbox

# ============================================================================
# FINANCING & QUOTE SERVICES
# ============================================================================

# GoodLeap
GOODLEAP_API_KEY=your_goodleap_api_key_here
GOODLEAP_API_SECRET=your_goodleap_api_secret_here

# Mosaic
MOSAIC_API_KEY=your_mosaic_api_key_here

# Sunlight
SUNLIGHT_API_KEY=your_sunlight_api_key_here

# Lightreach
LIGHTREACH_API_KEY=your_lightreach_api_key_here

# ============================================================================
# PAYMENT PROCESSING
# ============================================================================

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ============================================================================
# AUTHENTICATION & IDENTITY
# ============================================================================

# Auth0
AUTH0_DOMAIN=your_auth0_domain_here
AUTH0_CLIENT_ID=your_auth0_client_id_here
AUTH0_CLIENT_SECRET=your_auth0_client_secret_here
AUTH0_API_AUDIENCE=https://api.sunbull.ai

# ============================================================================
# CRM & MARKETING
# ============================================================================

# HubSpot
HUBSPOT_API_KEY=your_hubspot_api_key_here

# Meta (Facebook)
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_PIXEL_ID=your_meta_pixel_id_here

# ============================================================================
# SECURITY & ENCRYPTION
# ============================================================================

ENCRYPTION_KEY=your_encryption_key_here_min_32_chars
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# ============================================================================
# CLOUD & STORAGE
# ============================================================================

# Google Cloud Platform
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_STORAGE_BUCKET=sunbull-storage
GCP_SERVICE_ACCOUNT_KEY={}

# AWS (optional, if used instead of GCP)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_BUCKET=sunbull-storage

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Analytics
SEGMENT_WRITE_KEY=your_segment_write_key_here

# Logging
SENTRY_DSN=your_sentry_dsn_here

# Error Tracking
ERROR_TRACKING_URL=https://sentry.io/...

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# API Base URLs
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Feature Flags
FEATURE_DOCUSIGN_ENABLED=true
FEATURE_FINANCING_QUOTES_ENABLED=true
FEATURE_AI_RECOMMENDATIONS_ENABLED=true
FEATURE_MULTI_LANGUAGE_ENABLED=false

# Logging Level
LOG_LEVEL=debug

# CORS Settings
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

DEBUG=false
MOCK_EXTERNAL_SERVICES=false
SEED_DATABASE=false
