# Sunbull AI ML Service Configuration

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=86400

# Model Configuration
MODEL_PATH=/app/models/trained
USE_MODEL_CACHE=true

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "https://sunbull.ai"]
